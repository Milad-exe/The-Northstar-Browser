{
  "name": "northstar-browser",
  "version": "1.0.0",
  "description": "productivity web browser",
  "homepage": "https://github.com/Milad-exe/Northstar#readme",
  "bugs": {
    "url": "https://github.com/Milad-exe/Northstar/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Milad-exe/Northstar.git"
  },
  "license": "ISC",
  "author": "Milad Rakhshbahar",
  "type": "commonjs",
  "main": "app/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "node scripts/dev.js",
    "build": "npm run build:ts && npm run build:assets && npm run build:css",
    "build:ts": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "build:css": "tailwindcss -i src/renderer/styles/ui.css -o app/renderer/styles/ui.css",
    "build:assets": "node scripts/copy-assets.js",
    "watch": "tsc -p tsconfig.main.json --watch",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "dist": "node scripts/dist.js",
    "dist:win": "node scripts/dist.js win",
    "dist:mac": "node scripts/dist.js mac",
    "dist:linux": "node scripts/dist.js linux",
    "vmp-sign": "node scripts/vmp-sign.js node_modules/electron/dist",
    "test:permissions": "npm run build:ts && electron scripts/test-permissions.js",
    "smoke": "npm run build && node scripts/smoke.js"
  },
  "build": {
    "appId": "com.northstar.browser",
    "afterPack": "./scripts/vmp-sign.js",
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/"
    },
    "productName": "Northstar",
    "copyright": "Copyright \u00a9 2025 Milad Rakhshbahar",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "package.json",
      "logo.png",
      "logo-win.png",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/electron-chrome-extensions/**",
      "node_modules/electron-chrome-web-store/**"
    ],
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        "nsis"
      ],
      "signtoolOptions": {
        "sign": "./scripts/vmp-sign.js"
      }
    },
    "mac": {
      "icon": "icons/icon.icns",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": [
        "AppImage"
      ],
      "syncDesktopName": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "dompurify": "^3.4.10",
    "electron-chrome-extensions": "^4.9.0",
    "electron-chrome-web-store": "^0.13.0",
    "tldts": "^7.4.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^26.1.1",
    "electron": "github:castlabs/electron-releases#v38.8.6+wvcus",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2"
  }
}
