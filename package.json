{
  "name": "the-ink-browser",
  "version": "1.0.0",
  "description": "productivity web browser",
  "homepage": "https://github.com/Milad-exe/The-Ink-Browser#readme",
  "bugs": {
    "url": "https://github.com/Milad-exe/The-Ink-Browser/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Milad-exe/The-Ink-Browser.git"
  },
  "license": "ISC",
  "author": "Milad Rakhshbahar",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "jest"
  },
  "build": {
    "appId": "com.inkbrowser.app",
    "productName": "The Ink Browser",
    "copyright": "Copyright © 2025 Milad Rakhshbahar",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "logo.png",
      "Features/**/*",
      "ipc/**/*",
      "preload/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "icon": "icons/icon.ico",
      "target": ["nsis"]
    },
    "mac": {
      "icon": "icons/icon.icns",
      "target": ["dmg"],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": ["AppImage"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "dompurify": "^3.4.10",
    "tldts": "^7.4.2"
  },
  "devDependencies": {
    "electron": "^38.1.2",
    "electron-builder": "^26.15.3"
  }
}
