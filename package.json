{
  "name": "northstar-browser",
  "version": "1.0.0",
  "description": "productivity web browser",
  "homepage": "https://github.com/Milad-exe/Northstar#readme",
  "bugs": {
    "url": "https://github.com/Milad-exe/Northstar/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Milad-exe/Northstar.git"
  },
  "license": "ISC",
  "author": "Milad Rakhshbahar",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "vmp-sign": "python3 -m castlabs_evs.vmp sign-pkg node_modules/electron/dist",
    "test": "jest"
  },
  "build": {
    "appId": "com.northstar.browser",
    "afterPack": "./scripts/vmp-sign.js",
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/"
    },
    "productName": "Northstar",
    "copyright": "Copyright © 2025 Milad Rakhshbahar",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "logo.png",
      "Features/**/*",
      "ipc/**/*",
      "preload/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/electron-chrome-extensions/**",
      "node_modules/electron-chrome-web-store/**"
    ],
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "icons/icon.icns",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "dompurify": "^3.4.10",
    "electron-chrome-extensions": "^4.9.0",
    "electron-chrome-web-store": "^0.13.0",
    "tldts": "^7.4.2"
  },
  "devDependencies": {
    "electron": "github:castlabs/electron-releases#v38.8.6+wvcus",
    "electron-builder": "^26.15.3"
  }
}
